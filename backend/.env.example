# Environment Configuration for Production

# Application Settings
PROJECT_NAME="TerraChatBi"
CONTEXT_PATH=""
ALLOWED_HOSTS="*"
FRONTEND_HOST=http://localhost:5173

# CORS Settings
BACKEND_CORS_ORIGINS="http://localhost:5173"

# Langfuse Settings
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_HOST=https://cloud.langfuse.com

# Database Settings (app connects to db container via docker network)
POSTGRES_SERVER=agent-db
POSTGRES_PORT=5432
POSTGRES_USER=root
POSTGRES_PASSWORD="Password123@pg"
POSTGRES_DB=terra-agent
# 可选：使用完整的数据库URL（如果设置，将覆盖上述单独配置）
# TERRA_DB_URL=postgresql+psycopg://user:password@host:port/dbname

# JWT Configuration
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30
DEFAULT_PWD="Terra@123456"
ASSISTANT_TOKEN_KEY="X-TERRA-ASSISTANT-TOKEN"

# Cache Settings
CACHE_TYPE=memory
# Redis URL, e.g., "redis://[[username]:[password]]@localhost:6379/0"
# CACHE_REDIS_URL=redis://localhost:6379/0

# Logging Configuration
LOG_DIR=logs
LOG_LEVEL=DEBUG
LOG_FORMAT=json
SQL_DEBUG=false

# Base Directory Settings
BASE_DIR=/opt/terra-chatbi
SCRIPT_DIR=/opt/terra-chatbi/scripts
UPLOAD_DIR=/opt/terra-chatbi/data/file

# License Settings
SQLBOT_KEY_EXPIRED=100

# MCP/Image Settings
MCP_IMAGE_PATH=/opt/terra-chatbi/images
EXCEL_PATH=/opt/terra-chatbi/data/excel
MCP_IMAGE_HOST=http://localhost:3000
SERVER_IMAGE_HOST=http://YOUR_SERVE_IP:MCP_PORT/images/
SERVER_IMAGE_TIMEOUT=15

# SQL Generation Settings
GENERATE_SQL_QUERY_LIMIT_ENABLED=true
GENERATE_SQL_QUERY_HISTORY_ROUND_COUNT=3

# PostgreSQL Pool Settings
PG_POOL_SIZE=20
PG_MAX_OVERFLOW=30
PG_POOL_RECYCLE=3600
PG_POOL_PRE_PING=true

# Rate Limiting Settings (Production: stricter limits)
# RATE_LIMIT_DEFAULT uses JSON array format for list type
RATE_LIMIT_DEFAULT=["200 per day", "50 per hour"]
RATE_LIMIT_CHAT="30 per minute"
RATE_LIMIT_CHAT_STREAM="20 per minute"
RATE_LIMIT_MESSAGES="50 per minute"
RATE_LIMIT_LOGIN="20 per minute"

# RAG Settings
RAG_UPLOAD_DIR=/opt/terra-agent/data/rag
RAG_DEFAULT_CHUNK_SIZE=512
RAG_DEFAULT_CHUNK_OVERLAP=64
RAG_EMBEDDING_BATCH_SIZE=32
RAG_EMBEDDING_DIMENSION=1536
RAG_SEARCH_DEFAULT_TOP_K=5
RAG_KEYWORD_TOP_K=20
RAG_VECTOR_TABLE_NAME=rag_vectors
# Cross-encoder rerank model (leave empty to disable reranking)
RAG_RERANK_MODEL=""

# NL2SQL Settings
NL2SQL_CONNECT_TIMEOUT=10
NL2SQL_SCHEMA_SYNC_BATCH_SIZE=50
NL2SQL_DEFAULT_TOP_K_DDL=10
NL2SQL_DEFAULT_TOP_K_SQL=5
NL2SQL_DEFAULT_TOP_K_DOC=5
NL2SQL_SIMILARITY_THRESHOLD=0.3
